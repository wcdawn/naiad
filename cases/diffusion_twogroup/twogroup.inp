xslib twogroup.xs

# diamond_difference , linear_discontinuous , step_characteristic , linear_characteristic , quadratic_characteristic
spatial_method diamond_difference

nx 5

dx 10.0 10.0 10.0 10.0 10.0
mat_map FUEL FUEL FUEL FUEL FUEL

refine 8

snorder 0
bc_left mirror
bc_right zero

analysis_reference twogroup

tol_phi 1e-10
tol_k 1e-10
